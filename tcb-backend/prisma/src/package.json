{
  "name": "tcb-backend",
  "version": "1.0.0",
  "description": "The Corporate Blog - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "audit:indexing": "tsx src/seo/utils/indexing.audit.ts",
    "audit:seo": "tsx src/seo/utils/seo.acceptance.ts",
    "seo:signoff": "tsx src/seo/utils/seo.signoff.ts",
    "scheduler": "tsx src/posts/services/scheduler.cron.ts",
    "db:monitor": "tsx scripts/db-monitor.ts",
    "db:migrate:search": "psql $DATABASE_URL -f prisma/migrations/add_search_index/migration.sql",
    "load-test": "node scripts/load-test.mjs",
    "load-test:heavy": "node scripts/load-test.mjs 500 2000"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "form-data": "^4.0.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "optionalDependencies": {
    "@sentry/node": "^8.55.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.37",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "tsx": "^4.6.2",
    "typescript": "^5.9.3"
  }
}
